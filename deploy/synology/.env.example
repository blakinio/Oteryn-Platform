# Copy to .env outside Git history. Never commit the rendered file.
COMPOSE_PROJECT_NAME=oteryn-staging

# Safe defaults keep every published service on Synology loopback. For deliberate
# LAN-only native game testing, change only CANARY_GAME_BIND_ADDRESS,
# CANARY_SERVER_IP and GAME_WORLD_HOST to the exact private NAS address.
PLATFORM_BIND_ADDRESS=127.0.0.1
GATEWAY_BIND_ADDRESS=127.0.0.1
CANARY_LOGIN_BIND_ADDRESS=127.0.0.1
CANARY_GAME_BIND_ADDRESS=127.0.0.1
PLATFORM_PORT=8000
GATEWAY_PORT=8080
CANARY_LOGIN_PORT=7171
CANARY_GAME_PORT=7172

# Platform-owned authoritative route returned to OTClient after native login.
# GAME_WORLD_ID must match the exact Canary Game Session issuer world ID.
GAME_WORLD_ID=1
GAME_WORLD_SLUG=oteryn-staging
GAME_WORLD_NAME=Oteryn Staging
GAME_WORLD_REGION=LAN
GAME_WORLD_HOST=127.0.0.1
GAME_WORLD_PORT=7172

# Platform and Gateway images are built by GitHub Actions from this repository.
PLATFORM_IMAGE=ghcr.io/blakinio/oteryn-platform:main
GATEWAY_IMAGE=ghcr.io/blakinio/oteryn-game-gateway:main

# Required external prebuilt image containing the compatible Canary runtime and
# Oteryn Game Session issuer implementation. Do not point this at an unverified
# upstream image if native-auth testing is expected.
CANARY_IMAGE=REQUIRED_SET_PREBUILT_CANARY_IMAGE

# Platform application configuration.
APP_NAME=Oteryn Platform Staging
APP_ENV=staging
APP_DEBUG=false
APP_KEY=REQUIRED_GENERATE_LARAVEL_APP_KEY
APP_URL=http://127.0.0.1:8000
LOG_LEVEL=info
SESSION_SECURE_COOKIE=false

# MariaDB. Generate staging-only random values, preferably hex strings.
MARIADB_ROOT_PASSWORD=REQUIRED_RANDOM_HEX
PLATFORM_DB_NAME=oteryn_platform
PLATFORM_DB_USER=oteryn_platform
PLATFORM_DB_PASSWORD=REQUIRED_RANDOM_HEX
CANARY_DB_NAME=canary
CANARY_DB_USER=canary
CANARY_DB_PASSWORD=REQUIRED_RANDOM_HEX

# Dedicated Platform -> Canary least-privilege credentials. The deploy script
# renders the repository-owned grant templates only after the Canary schema is ready.
CANARY_READONLY_DB_USER=oteryn_readonly
CANARY_READONLY_DB_PASSWORD=REQUIRED_RANDOM_HEX
CANARY_PROVISIONING_DB_USER=oteryn_provisioning
CANARY_PROVISIONING_DB_PASSWORD=REQUIRED_RANDOM_HEX
CANARY_CHARACTER_CREATE_DB_USER=oteryn_character_create
CANARY_CHARACTER_CREATE_DB_PASSWORD=REQUIRED_RANDOM_HEX

# Redis default/admin password and Platform read-only runtime ACL credential.
REDIS_PASSWORD=REQUIRED_RANDOM_HEX
CANARY_RUNTIME_REDIS_USERNAME=oteryn_runtime
CANARY_RUNTIME_REDIS_PASSWORD=REQUIRED_RANDOM_HEX

# Gateway -> Platform service credential. Plaintext belongs only to Gateway;
# Platform receives its SHA-256 digest.
OTERYN_PLATFORM_SERVICE_TOKEN=REQUIRED_RANDOM_HEX
GAME_AUTH_GATEWAY_SERVICE_TOKEN_SHA256=REQUIRED_SHA256_OF_PLATFORM_SERVICE_TOKEN
GAME_AUTH_GATEWAY_PREVIOUS_SERVICE_TOKEN_SHA256=

# Gateway -> Canary session issuer service credential. Plaintext belongs only to
# Gateway; Canary receives its SHA-256 digest.
GAME_SESSION_SERVICE_TOKEN=REQUIRED_RANDOM_HEX
CANARY_GAME_SESSION_SERVICE_TOKEN_SHA256=REQUIRED_SHA256_OF_GAME_SESSION_SERVICE_TOKEN
CANARY_GAME_SESSION_PREVIOUS_SERVICE_TOKEN_SHA256=

# Canary quickstart-compatible runtime settings. CANARY_SERVER_IP must equal the
# game bind/World Registry address so clients never receive an unreachable route.
CANARY_SERVER_NAME=Oteryn Staging
CANARY_SERVER_IP=127.0.0.1
CANARY_TEST_ACCOUNTS=false
CANARY_DATA_PACK=data-otservbr-global
CANARY_MAP_URL=https://github.com/opentibiabr/canary/releases/download/v3.6.1/otservbr.otbm

# Persistent rollback state for the self-hosted runner. This path is on the runner
# host, not inside Git. Override if the runner container mounts a different state path.
OTERYN_STATE_DIR=/var/lib/oteryn-staging-state
