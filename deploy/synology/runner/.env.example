# Copy to .env only for first registration. Remove RUNNER_TOKEN from the project
# configuration after the runner appears online; the persistent runner_config volume
# retains the registered runner credentials.
RUNNER_IMAGE=ghcr.io/blakinio/oteryn-deploy-runner:main
RUNNER_NAME=oteryn-synology-staging
RUNNER_TOKEN=REQUIRED_ONE_TIME_REGISTRATION_TOKEN
OTERYN_STATE_HOST_PATH=/volume1/docker/oteryn/state
