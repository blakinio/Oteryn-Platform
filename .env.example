APP_NAME="Oteryn Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

# Read-only Canary connection for public game-data queries.
# In non-test environments, use a database user restricted to SELECT on only the required tables.
CANARY_DB_HOST=127.0.0.1
CANARY_DB_PORT=3306
CANARY_DB_DATABASE=canary
CANARY_DB_USERNAME=oteryn_readonly
CANARY_DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=file
QUEUE_CONNECTION=sync

# Safe local default: reset links remain in-memory instead of being written to application logs.
# Production should configure a real mail transport and inject credentials outside Git.
MAIL_MAILER=array
MAIL_FROM_ADDRESS="noreply@example.test"
MAIL_FROM_NAME="${APP_NAME}"
