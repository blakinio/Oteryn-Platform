APP_NAME="Oteryn Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Comma-separated IP addresses or CIDRs for the TLS-terminating reverse proxies
# that are allowed to supply X-Forwarded-* metadata. Leave empty for direct/local
# serving. Wildcard trust is rejected so public clients cannot spoof HTTPS/host data.
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Approved public support channels. URLs must use HTTPS and match their comma-separated
# host allowlists; invalid or unapproved values are omitted from public output.
OTERYN_SUPPORT_DISCORD_URL=
OTERYN_SUPPORT_DISCORD_HOSTS=discord.gg,discord.com
OTERYN_SUPPORT_CONTACT_EMAIL=
OTERYN_SUPPORT_URL=
OTERYN_SUPPORT_ALLOWED_HOSTS=

# Native game-auth ticket boundary. Inject only SHA-256 hashes of Gateway service
# credentials here; the plaintext Gateway bearer token belongs in the deployment
# secret store. During rotation, set PREVIOUS to the retiring hash, deploy the new
# current hash and caller credential, then clear PREVIOUS after the overlap window.
GAME_AUTH_TICKET_TTL_SECONDS=60
GAME_AUTH_GATEWAY_SERVICE_TOKEN_SHA256=
GAME_AUTH_GATEWAY_PREVIOUS_SERVICE_TOKEN_SHA256=

DB_CONNECTION=sqlite

# Read-only Canary connection for public game-data queries.
# In non-test environments, use a database user restricted to SELECT on only the required tables.
CANARY_DB_HOST=127.0.0.1
CANARY_DB_PORT=3306
CANARY_DB_DATABASE=canary
CANARY_DB_USERNAME=oteryn_readonly
CANARY_DB_PASSWORD=

# Dedicated Canary account-provisioning connection.
# Never reuse the read-only or Canary game-process credential. Provision exactly the
# column-level accounts INSERT/SELECT grants from database/provisioning/canary-provisioning.sql.template.
CANARY_PROVISIONING_DB_HOST=127.0.0.1
CANARY_PROVISIONING_DB_PORT=3306
CANARY_PROVISIONING_DB_DATABASE=canary
CANARY_PROVISIONING_DB_USERNAME=oteryn_provisioning
CANARY_PROVISIONING_DB_PASSWORD=

# Dedicated Canary character-create connection.
# Never reuse the read-only, account-provisioning or Canary game-process credential.
# Provision exactly the column-level grants from database/provisioning/canary-character-create.sql.template.
CANARY_CHARACTER_CREATE_DB_HOST=127.0.0.1
CANARY_CHARACTER_CREATE_DB_PORT=3306
CANARY_CHARACTER_CREATE_DB_DATABASE=canary
CANARY_CHARACTER_CREATE_DB_USERNAME=oteryn_character_create
CANARY_CHARACTER_CREATE_DB_PASSWORD=

# Dedicated read-only Canary runtime Redis connection.
# Provision an ACL/user restricted to deterministic cluster:channel:*:runtime reads only.
# Do not reuse Canary game-process write credentials or a Platform cache/session Redis credential.
CANARY_RUNTIME_REDIS_CLIENT=phpredis
CANARY_RUNTIME_REDIS_SCHEME=tcp
CANARY_RUNTIME_REDIS_HOST=127.0.0.1
CANARY_RUNTIME_REDIS_PORT=6379
CANARY_RUNTIME_REDIS_USERNAME=
CANARY_RUNTIME_REDIS_PASSWORD=
CANARY_RUNTIME_REDIS_DB=0
CANARY_RUNTIME_REDIS_TIMEOUT=2.0
CANARY_RUNTIME_REDIS_READ_TIMEOUT=2.0

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=file
QUEUE_CONNECTION=sync

# Safe local default: reset links remain in-memory instead of being written to application logs.
# Production should configure a real mail transport and inject credentials outside Git.
MAIL_MAILER=array
